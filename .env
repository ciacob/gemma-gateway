# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:e4b

# Server
PORT=3000
HOST=127.0.0.1

# Model lifecycle
# How long (seconds) Ollama keeps the model loaded after the last request
MODEL_KEEP_ALIVE_SECONDS=300
# How long (seconds) of server-side inactivity before we explicitly unload the model
IDLE_TTL_SECONDS=360

# Queue
# Max concurrent requests sent to Ollama at once
QUEUE_CONCURRENCY=1
# Max requests allowed to queue up (beyond this, new requests get 429)
QUEUE_MAX_SIZE=20

# Uploads (multipart)
MAX_UPLOAD_BYTES=52428800

# Context chat sessions
# Directory where cached sessions are stored (relative to cwd or absolute)
SESSION_CACHE_DIR=sessions
# Model context window in tokens (gemma4:e4b = 128K, gemma4:12b = 128K)
MODEL_CONTEXT_TOKENS=131072
# Summarise history when estimated token usage crosses this % of the context window
CONTEXT_SUMMARIZE_THRESHOLD=70
# Number of most-recent raw turns to keep verbatim during summarisation
CONTEXT_SUMMARY_KEEP_RECENT=10
