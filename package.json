{
  "name": "gemma-gateway",
  "version": "1.0.0",
  "description": "Fastify gateway for local Gemma 4 via Ollama — text, image, audio",
  "main": "server.js",
  "scripts": {
    "start":       "node server.js",
    "dev":         "node --watch server.js",
    "test":        "node --test test/*.test.js",
    "test:watch":  "node --test --watch test/*.test.js",
    "pm2:start":   "pm2 start ecosystem.config.js",
    "pm2:stop":    "pm2 stop gemma-gateway",
    "pm2:restart": "pm2 restart gemma-gateway",
    "pm2:logs":    "pm2 logs gemma-gateway",
    "pm2:monit":   "pm2 monit"
  },
  "dependencies": {
    "@fastify/multipart": "^9.0.3",
    "dotenv": "^16.5.0",
    "fastify": "^5.3.2",
    "p-queue": "^8.1.0",
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "pm2": "^5.4.3"
  }
}
